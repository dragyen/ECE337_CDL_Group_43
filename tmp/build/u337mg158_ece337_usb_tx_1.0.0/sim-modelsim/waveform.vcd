$var wire 1 @ buffer_occupancy [4] $end
$var wire 1 A buffer_occupancy [3] $end
$var wire 1 B buffer_occupancy [2] $end
$var wire 1 C buffer_occupancy [1] $end
$var wire 1 D buffer_occupancy [0] $end
$var reg 1 E get_tx_packet_data $end
$var reg 1 F tx_transfer_active $end
$var reg 1 G tx_error $end
$var reg 1 H dm_out $end
$var reg 1 I dp_out $end
$var reg 4 J currentState [3:0] $end
$var reg 4 K nextState [3:0] $end
$var reg 1 L shift_en $end
$var reg 1 M load_en $end
$var reg 1 N bit_pulse $end
$var reg 5 O bit_counter [4:0] $end
$var reg 5 P next_bit_counter [4:0] $end
$var reg 3 Q ones_count [2:0] $end
$var reg 3 R next_ones_count [2:0] $end
$var reg 1 S stuff_active $end
$var reg 1 T next_stuff_active $end
$var reg 16 U crc16 [15:0] $end
$var reg 16 V next_crc16 [15:0] $end
$var reg 1 W nrzi_bit $end
$var reg 4 X pid [3:0] $end
$var reg 8 Y sr_load_data [7:0] $end
$var reg 2 Z pattern_state [1:0] $end
$var reg 4 [ rollover_val [3:0] $end
$var reg 1 \ serial_out $end
$var reg 16 ] crc16_inv [15:0] $end
$var reg 1 ^ fb $end
$var reg 1 _ dp_orig $end
$var reg 1 ` next_dp_orig $end

$scope module clk_div $end
$var parameter 32 a SIZE $end
$var wire 1 1 clk $end
$var wire 1 2 n_rst $end
$var wire 1 b clear $end
$var wire 1 c count_enable $end
$var wire 1 d rollover_val [3] $end
$var wire 1 e rollover_val [2] $end
$var wire 1 f rollover_val [1] $end
$var wire 1 g rollover_val [0] $end
$var reg 4 h count_out [3:0] $end
$var reg 1 i rollover_flag $end
$var reg 4 j next_count_out [3:0] $end
$var reg 1 k next_rollover_flag $end
$upscope $end

$scope module data_sr $end
$var parameter 32 l SIZE $end
$var parameter 32 m MSB_FIRST $end
$var wire 1 1 clk $end
$var wire 1 2 n_rst $end
$var wire 1 n shift_enable $end
$var wire 1 o load_enable $end
$var wire 1 p serial_in $end
$var wire 1 q parallel_in [7] $end
