$var wire 1 x parallel_in [0] $end
$var reg 1 y serial_out $end
$var reg 8 z parallel_out [7:0] $end
$var reg 8 { next_parallel_out [7:0] $end
$upscope $end
$upscope $end
$upscope $end

$scope begin std $end
$upscope $end
$enddefinitions $end
