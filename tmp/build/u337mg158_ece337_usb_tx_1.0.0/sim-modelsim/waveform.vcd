	Fri Apr 17 14:07:55 2026
$end
$version
	QuestaSim Version 2021.4
$end
$timescale
	1ps
$end

$scope module tb_usb_tx $end
$var parameter 0 ! CLK_PERIOD $end
$var parameter 16 " EXPECTED_CRC $end
$var reg 1 # clk $end
$var reg 1 $ n_rst $end
$var reg 8 % tx_packet_data [7:0] $end
$var reg 3 & tx_packet [2:0] $end
$var reg 7 ' buffer_occupancy [6:0] $end
$var reg 1 ( get_tx_packet_data $end
$var reg 1 ) tx_transfer_active $end
$var reg 1 * tx_error $end
$var reg 1 + dm_out $end
$var reg 1 , dp_out $end
$var reg 1 - prev_dp $end

$scope task reset_dut $end
$upscope $end

$scope task init_signals $end
$upscope $end

$scope begin stuffing_check $end
$var integer 32 . i $end
$var reg 1 / expected_dp $end
$upscope $end

$scope begin crc_wire_check $end
$var integer 32 0 i $end
$upscope $end

$scope module DUT $end
$var wire 1 1 clk $end
$var wire 1 2 n_rst $end
$var wire 1 3 tx_packet_data [7] $end
$var wire 1 4 tx_packet_data [6] $end
