$timescale
	1ps
$end

$scope module tb_usb_tx $end
$var parameter 0 ! CLK_PERIOD $end
$var reg 1 " clk $end
$var reg 1 # n_rst $end
$var reg 8 $ tx_packet_data [7:0] $end
$var reg 3 % tx_packet [2:0] $end
$var reg 7 & buffer_occupancy [6:0] $end
$var reg 1 ' get_tx_packet_data $end
$var reg 1 ( tx_transfer_active $end
$var reg 1 ) tx_error $end
$var reg 1 * dm_out $end
$var reg 1 + dp_out $end
$var reg 1 , prev_dp $end

$scope task reset_dut $end
$upscope $end

$scope task init_signals $end
$upscope $end

$scope module DUT $end
$var wire 1 - clk $end
$var wire 1 . n_rst $end
$var wire 1 / tx_packet_data [7] $end
